rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic auth check
    function isSignedIn() {
      return request.auth != null;
    }

    // Simple user exists check
    function userExists(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    // Safe role getter - won't crash if user doesn't exist
    function safeGetRole(uid) {
      return userExists(uid) ? get(/databases/$(database)/documents/users/$(uid)).data.role : '';
    }

    // Role checkers that won't crash
    function isPatient() {
      return isSignedIn() && safeGetRole(request.auth.uid) == 'patient';
    }

    function isTherapist() {
      return isSignedIn() && safeGetRole(request.auth.uid) == 'therapist';
    }

    // USERS collection - Core for everything
    match /users/{userId} {
      // Anyone signed in can read any user (needed for UI display)
      allow read: if isSignedIn();
      
      // Users can only create their own profile
      allow create: if isSignedIn() 
        && request.auth.uid == userId
        && request.resource.data.role in ['patient', 'therapist'];
      
      // Users can only update their own profile
      allow update: if isSignedIn() && request.auth.uid == userId;
      
      // No deletes
      allow delete: if false;
    }

    // SESSIONS collection
    match /sessions/{sessionId} {
      allow read: if isSignedIn() && (
        resource.data.patientId == request.auth.uid ||
        resource.data.therapistId == request.auth.uid
      );
      
      allow create: if isSignedIn() 
        && isPatient()
        && request.resource.data.patientId == request.auth.uid;
      
      allow update, delete: if isSignedIn() && (
        resource.data.patientId == request.auth.uid ||
        resource.data.therapistId == request.auth.uid
      );
    }

    // JOURNALS collection
    match /journals/{journalId} {
      allow create: if isSignedIn()
        && isPatient()
        && request.resource.data.userId == request.auth.uid;

      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        (isTherapist() && resource.data.role == 'patient')
      );

      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;

      allow delete: if isSignedIn() 
        && resource.data.userId == request.auth.uid;
    }

    // REPORTS collection
    match /reports/{reportId} {
      allow read: if isSignedIn() && (
        resource.data.patientId == request.auth.uid ||
        resource.data.therapistId == request.auth.uid
      );

      allow create: if isSignedIn()
        && isTherapist()
        && request.resource.data.therapistId == request.auth.uid;

      allow update, delete: if isSignedIn()
        && isTherapist()
        && resource.data.therapistId == request.auth.uid;
    }

    // ASSIGNMENTS collection
    match /assignments/{assignmentId} {
      allow read: if isSignedIn() && (
        resource.data.therapistId == request.auth.uid ||
        resource.data.patientId == request.auth.uid
      );

      allow create: if isSignedIn()
        && isTherapist()
        && request.resource.data.therapistId == request.auth.uid;

      allow update: if isSignedIn() && (
        (isTherapist() && resource.data.therapistId == request.auth.uid) ||
        (isPatient() && resource.data.patientId == request.auth.uid)
      );

      allow delete: if isSignedIn()
        && isTherapist()
        && resource.data.therapistId == request.auth.uid;
    }

    // RESPONSES collection
    match /responses/{responseId} {
      allow read: if isSignedIn() && (
        resource.data.patientId == request.auth.uid ||
        resource.data.therapistId == request.auth.uid
      );

      allow create, update: if isSignedIn()
        && isPatient()
        && request.resource.data.patientId == request.auth.uid;

      allow delete: if false;
    }

    // THERAPIST-PATIENTS collection
    match /therapistPatients/{assignmentId} {
      allow read: if isSignedIn() && (
        resource.data.patientId == request.auth.uid ||
        resource.data.therapistId == request.auth.uid
      );

      allow create: if isSignedIn()
        && isPatient()
        && request.resource.data.patientId == request.auth.uid;

      allow update, delete: if false;
    }

    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
